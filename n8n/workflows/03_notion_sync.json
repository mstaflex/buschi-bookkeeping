            { "key": "Quelle",         "type": "select",   "selectValue": "={{$json.source}}" },
            { "key": "Status",         "type": "select",   "selectValue": "={{$json.status}}" },
            { "key": "Bestelldatum",   "type": "date",     "dateValue": "={{$json.order_date}}" },
            { "key": "Pseudonym",      "type": "richText", "textValue": "={{$json.pseudonym}}" },
            { "key": "Stadt",          "type": "richText", "textValue": "={{$json.city ?? ''}}" },
            { "key": "PLZ (Prefix)",   "type": "richText", "textValue": "={{$json.zip_prefix ?? ''}}" },
            { "key": "Land",           "type": "richText", "textValue": "={{$json.country ?? ''}}" },
            { "key": "Gesamt (€)",     "type": "number",   "numberValue": "={{$json.total}}" },
            { "key": "Versand (€)",    "type": "number",   "numberValue": "={{$json.shipping_cost}}" },
            { "key": "Währung",        "type": "select",   "selectValue": "={{$json.currency}}" },
            { "key": "Artikel",        "type": "richText", "textValue": "={{$json.items_summary}}" },
            { "key": "Digital",        "type": "checkbox", "checkboxValue": "={{$json.is_digital}}" },
            { "key": "Rechnungsnr.",   "type": "richText", "textValue": "={{$json.invoice_number ?? ''}}" },
            { "key": "Tracking",       "type": "richText", "textValue": "={{$json.tracking_number ?? ''}}" },
            { "key": "Versanddienstl.","type": "richText", "textValue": "={{$json.carrier ?? ''}}" }
          ]
        }
      },
      "id": "c3d4e5f6-0003-0003-0003-000000000006",
      "name": "Notion Page erstellen",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [1340, 140],
      "credentials": {
