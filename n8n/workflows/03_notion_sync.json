        }
      },
      "id": "c3d4e5f6-0003-0003-0003-000000000001",
      "name": "Stündlich",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  order_id,\n  source,\n  order_date,\n  buyer_name,\n  buyer_email,\n  buyer_city,\n  buyer_zip,\n  buyer_country,\n  items_json,\n  subtotal,\n  shipping_cost,\n  total,\n  currency,\n  status,\n  tracking_number,\n  carrier,\n  invoice_number,\n  is_digital,\n  notion_page_id\nFROM orders\nWHERE updated_at > NOW() - INTERVAL '2 hours'\n  AND source = 'etsy'\nORDER BY updated_at DESC;",
        "options": {}
      },
      "id": "c3d4e5f6-0003-0003-0003-000000000002",
      "name": "Geänderte Orders holen",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [460, 300],
      "credentials": {
        "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "orderdb" }
      }
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "has-rows",
              "leftValue": "={{$input.all().length}}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }
            }
          ]
        }
      },
      "id": "c3d4e5f6-0003-0003-0003-000000000003",
      "name": "Neue / geänderte Orders?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "// PII-Anonymisierung für Notion (DSGVO-konform)\n// Was bleibt:    Pseudonym, Stadt, Land, PLZ-Präfix (erste 2 Stellen), Finanzen, Status\n// Was entfällt:  Vollname, E-Mail, Straße, vollständige PLZ\n\nconst crypto = require('crypto');\n\nfunction pseudonym(name, email) {\n  // Stabile Pseudonymisierung: SHA-256 der E-Mail (oder des Namens),\n  // ersten 8 Zeichen als Hex-Suffix → z.B. \"Kunde-3f7a2b1c\"\n  const seed = (email || name || String(Math.random())).toLowerCase().trim();\n  const hash = crypto.createHash('sha256').update(seed).digest('hex').slice(0, 8);\n  return `Kunde-${hash}`;\n}\n\nreturn $input.all().map(item => {\n  const o = item.json;\n\n  // PLZ: nur erste 2 Zeichen (z.B. \"80\" statt \"80331\")\n  const zipPrefix = o.buyer_zip ? String(o.buyer_zip).slice(0, 2) + 'xxx' : null;\n\n  // Items: Titel + Menge behalten, Preise OK (keine PII)\n  let items = [];\n  try { items = JSON.parse(o.items_json ?? '[]'); } catch (e) {}\n  const itemsSummary = items.map(i => `${i.quantity}x ${i.title}`).join(', ');\n\n  return {\n    json: {\n      // Identifikatoren\n      order_id:       o.order_id,\n      notion_page_id: o.notion_page_id ?? null,\n      source:         o.source,\n      // Anonymisiert\n      pseudonym:      pseudonym(o.buyer_name, o.buyer_email),\n      city:           o.buyer_city ?? null,\n      zip_prefix:     zipPrefix,\n      country:        o.buyer_country ?? null,\n      // Geschäftsdaten (kein PII)\n      order_date:     o.order_date,\n      status:         o.status,\n      subtotal:       o.subtotal,\n      shipping_cost:  o.shipping_cost,\n      total:          o.total,\n      currency:       o.currency,\n      items_summary:  itemsSummary,\n      is_digital:     o.is_digital,\n      tracking_number: o.tracking_number ?? null,\n      carrier:        o.carrier ?? null,\n      invoice_number: o.invoice_number ?? null,\n    }\n  };\n});\n"
      },
      "id": "c3d4e5f6-0003-0003-0003-000000000004",
      "name": "Daten anonymisieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 220]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "has-page-id",
              "leftValue": "={{$json.notion_page_id}}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ]
        }
      },
      "id": "c3d4e5f6-0003-0003-0003-000000000005",
      "name": "Schon in Notion?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 220]
    },
    {
      "parameters": {
        "resource": "databasePage",
