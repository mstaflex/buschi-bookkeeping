# =============================================================================
# .env.example – all variables are OPTIONAL
#
# If a variable is omitted:
#   - Names  → sane defaults are used (DB_NAME=orderdb, DB_ADMIN_USER=root,
#               DB_WORKER_USER=buschi)
#   - Passwords → generated automatically (20 random alphanumeric characters)
#
# Generated credentials are printed ONCE to:
#   docker compose logs bootstrap
#
# Workflow:
#   1. Optionally copy to .env and fill in values
#   2. docker compose up -d
#   3. docker compose logs bootstrap   ← note down any generated credentials
#   4. rm .env                         ← credentials are now in secrets/*.txt
#
# IMPORTANT: never commit .env or secrets/*.txt to git!
# =============================================================================

# ---------------------------------------------------------------------------
# Etsy API (für n8n Workflows)
# Shop-ID: https://www.etsy.com/shop/<dein-shop> → Einstellungen → Info
# OAuth2-Credentials werden direkt in n8n hinterlegt (nicht hier)
# ---------------------------------------------------------------------------
# ETSY_SHOP_ID=12345678

# ---------------------------------------------------------------------------
# Notion (für n8n Workflow 03)
# Database-ID aus der Notion-URL: notion.so/<workspace>/<DATABASE_ID>?v=...
# ---------------------------------------------------------------------------
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DB_NAME=orderdb
# DB_ADMIN_USER=root
# DB_ADMIN_PASSWORD=my-strong-admin-password
# DB_WORKER_USER=buschi
# DB_WORKER_PASSWORD=my-strong-worker-password
