# =============================================================================
# .env.example – Vorlage für den ersten Start
#
# Anleitung:
#   1. Diese Datei nach ".env" kopieren
#   2. Werte eintragen
#   3. docker compose up -d
#   4. Nach erfolgreichem Start: .env löschen (Secrets liegen dann in secrets/)
#
# WICHTIG: .env niemals ins Git-Repository committen!
# =============================================================================

DB_NAME=orderdb
DB_ADMIN_USER=orderdb_admin
DB_ADMIN_PASSWORD=HIER_STARKES_PASSWORT_EINTRAGEN
DB_WORKER_USER=n8n_worker
DB_WORKER_PASSWORD=HIER_STARKES_PASSWORT_EINTRAGEN
